{
    "_preset_metadata": {
        "name": "minimal_enzyme",
        "scenario": "OpeRATOR only, no SialEXO or PNGaseF; for simple non-sialylated samples where pre-treatment is unnecessary.",
        "derived_from": "oglycan-optimizer defaults + enzyme_preprocessing.use_sialexo true -> false and enzyme_preprocessing.use_pngasef true -> false"
    },
    "enzyme_preprocessing": {
        "primary": "OpeRATOR",
        "use_sialexo": false,
        "use_pngasef": false,
        "digestion_time_hours": 4,
        "temperature_C": 37
    },
    "fragmentation": {
        "mode": "EThcD",
        "ethcd_sa_percent": 18,
        "collision_energy_nce": 30,
        "charge_state_min": 2,
        "charge_state_max": 6,
        "isolation_window_mz": 1.6
    },
    "ms_acquisition": {
        "resolution_ms1": 120000,
        "resolution_ms2": 30000,
        "agc_target_ms1": 1000000.0,
        "agc_target_ms2": 50000.0,
        "max_injection_ms1": 50,
        "max_injection_ms2": 250,
        "dynamic_exclusion_s": 30
    },
    "glycan_database": {
        "include_core1": true,
        "include_core2": true,
        "include_core3": true,
        "max_glycan_size": 6,
        "include_sialylated": true,
        "include_fucosylated": true
    },
    "search_params": {
        "mass_tolerance_ms1_ppm": 10,
        "mass_tolerance_ms2_ppm": 20,
        "min_peptide_length": 6,
        "max_missed_cleavages": 2,
        "fdr_threshold": 0.01
    },
    "lc_gradient": {
        "column": "C18_UHPLC",
        "gradient_start_pct_b": 2,
        "gradient_end_pct_b": 40,
        "gradient_time_min": 120,
        "flow_rate_uL_min": 300
    }
}
